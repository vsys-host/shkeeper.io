{% extends 'wallet/page.j2' %}


{% block content %}

      <div class="content-container">
        <div class="row">
          <div class="col">
            <h1 class="title-text">Wallets</h1>
          </div>
        </div>
        <div id="network-warning-banner" class="network-banner hidden">
          <div class="network-banner-content">
            <p>
              ⚠️ To send or receive tokens (USDT, USDC, PYUSD, DAI), your wallet must have a small amount of the network’s native coin (e.g. ETH, TRX, BNB, MATIC, AVAX, SOL, TON) to cover transaction fees.
              Without it, token transfers cannot be processed. To obtain a fee deposit account, please click the “Payout” button. You will find the field “Fee-deposit account:”, where the required information will be provided.
            </p>
            <button id="close-banner-btn" class="btn btn-outline-primary btn-outline-primary__customization" disabled>
               Close (10)
             </button>
          </div>
        </div>

        <div class="d-flex flex-wrap justify-content-center wallets-container">
          {% for crypto in cryptos %}

                    <div class="card">
                      <div class="card-body card-box">
                        <svg class="currency-logo" width="48" height="48">
                          <use href="{{ url_for('static', filename='images/icons.' + theme + '.svg') }}#wallets-{{ crypto.getname()|lower }}"></use>
                        </svg>
                        <div class="d-flex justify-content-between info-content">
                          <p class="common-text">Crypto:</p>
                          <p class="wallet-crypto common-text">{{ crypto.display_name }}</p>
                        </div>
                        <div class="d-flex justify-content-between info-content">
                          <p class="common-text">Server:</p>
                          <p class="server-status common-text success-text">{{ crypto.getstatus() }}</p>
                        </div>
                        <div class="d-flex justify-content-between info-content">
                          <p class="common-text">Wallet status:</p>
                          <p class="wallet-status common-text success-text">Active</p>
                        </div>
                        <div class="d-flex justify-content-between info-content">
                          <p class="common-text">Amount:</p>
                          <p class="coin-amount-value common-text" id="{{crypto.crypto}}">--</p>
                        </div>
                        <div class="d-flex justify-content-between info-content">
                          <p class="common-text">Exchange rate:</p>
                          <p class="common-text dollar">$</p>
                          <p class="current-exchange-value common-text" id="{{crypto.crypto}}USDT">--</p>
                        </div>
                        <div class="d-flex justify-content-between info-content">
                          <p class="common-text">USD equivalent:</p>
                          <p class="common-text dollar">$</p>
                          <p class="total-usd-value common-text">--</p>
                        </div>
                        <div class="d-flex justify-content-between info-content">
                          <p class="common-text">Payout policy:</p>
                          <p class="common-text success-text">{{crypto.wallet.ppolicy.value}}</p>
                        </div>
                        <div class="d-flex justify-content-between info-content">
                          <p class="common-text">Autopayout status:</p>
                          <p class="pstatus common-text success-text">{{crypto.wallet.payout}}</p>
                        </div>
                        <div class="d-flex justify-content-between info-content">
                          <p class="common-text">API status:</p>
                          <p crypto="{{crypto.crypto}}"class="apistatus common-text">Disabled</p>
                        </div>

                        <div class="d-flex justify-content-between">
                          <a href="./wallet/{{crypto.crypto}}" class="card-link common-text">
                            <svg class="card-icon" width="16" height="16">
                              <use href="{{ url_for('static', filename='images/icons.' + theme + '.svg') }}#gearsix-icon"></use>
                            </svg>
                            Manage
                          </a>
                          <a href="./payout/{{crypto.crypto}}" class="card-link common-text">
                            <svg class="card-icon" width="16" height="16">
                              <use href="{{ url_for('static', filename='images/icons.' + theme + '.svg') }}#circledollar-icon"></use>
                            </svg>
                            Payout
                          </a>
                        </div>
                      </div>
                    </div>

          {% endfor %}
        </div>

        <div class="row"></div>
      </div>
      <script
        src={{ url_for('static', filename='js/custom-wallets.js')}}
      >
      </script>
      <script>document.getElementById("wallet-link").classList.add("nav-link--active");</script>

{% endblock %}
